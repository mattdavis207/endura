{
  "expo": {
    "name": "Endura",
    "slug": "endura",
    "scheme": "endura",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.endura.mobile",
      "infoPlist": {
        "LSApplicationQueriesSchemes": ["strava"]
      }
    },
    "android": {
      "package": "com.endura.mobile"
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": ["expo-router", "expo-secure-store", "expo-web-browser"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
