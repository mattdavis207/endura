# Shared
APP_ENV=local

# Mobile
EXPO_PUBLIC_API_URL=http://localhost:8000
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# Backend
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/endura
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
CORS_ORIGINS=http://localhost:8081,http://localhost:19006

# Strava OAuth
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=

# AI provider: leave both empty until deciding between OpenAI and Claude.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Embeddings/model names can be set after provider choice.
AI_CHAT_MODEL=
AI_EMBEDDING_MODEL=
